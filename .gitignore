__pycache__/
*.pyc
*.egg-info/
results/
.ipynb_checkpoints/
.DS_Store

# viz layer (ROADMAP §8): renders are REGENERABLE outputs — only the recipe (code),
# a small exemplar (thumb.png), provenance (data.json) and GALLERY.md are tracked.
# Heavy stills stacks / videos / 3D volumes are gitignored.
docs/figures/viz/**/frames/
docs/figures/viz/**/*.mp4
docs/figures/viz/**/*.gif
docs/figures/viz/**/*.webm
*.vti
*.vtu

# Phase 0 raw data drops — kept on disk for reference, not tracked.
# Curated CSVs, PROVENANCE.md, and small source/ files ARE tracked (force-added).
# pannusch2024: whole Mendeley repo bulk ignored except its PROVENANCE.md
puckworks/data/pannusch2024/*
!puckworks/data/pannusch2024/PROVENANCE.md
!puckworks/data/pannusch2024/table2_fitted_params.csv
!puckworks/data/pannusch2024/table2_grind_psi_ds2.csv
!puckworks/data/pannusch2024/experimental_kinetics.csv
# visualizer.coffee: user-contributed shot CORPUS has NO research-use license
# (visualizer app is MIT, app code only). The raw harvested store is NEVER
# committed (ROADMAP 0.13). Only PROVENANCE.md and the small DERIVED
# aggregate_stats.csv are tracked (force-added), exactly like pannusch2024.
puckworks/data/visualizer/*
!puckworks/data/visualizer/PROVENANCE.md
!puckworks/data/visualizer/aggregate_stats.csv
# schmieder2023: large MDPI binaries + extracted supplementary dirs
puckworks/data/schmieder2023/*.zip
puckworks/data/schmieder2023/*.epub
puckworks/data/schmieder2023/*.pdf
puckworks/data/schmieder2023/*.opju
puckworks/data/schmieder2023/foods-12-02871-s001/
puckworks/data/schmieder2023/foods-12-02871-s001*/

# handoff delivery bundle (binary; contents integrated into the tree)
docs/puckworks_handoff_2026-07-13.zip

# figure vector siblings are regenerable render outputs (produced at release render);
# only the committed PNG exemplars + the export code are tracked.
docs/figures/**/*.svg
docs/figures/**/*.pdf
docs/figures/*.svg
docs/figures/*.pdf
